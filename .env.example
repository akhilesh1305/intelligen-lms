# Local development (with docker compose up -d)
DATABASE_URL="postgresql://intelligen:intelligen@localhost:5432/intelligen_lms"
SESSION_SECRET="change-this-to-a-long-random-string-in-production"
PORT=3001
AVATAR_STORAGE="filesystem"

# Production (Railway) — set these in Railway dashboard
# DATABASE_URL="postgresql://..."  (from Railway PostgreSQL)
# SESSION_SECRET="..."             (openssl rand -base64 32)
# NODE_ENV="production"
# AVATAR_STORAGE="database"

# Email (optional — logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="IntelliGen LMS <noreply@intelligen.lms>"

# AI Assistant (optional — uses smart local engine without this)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
