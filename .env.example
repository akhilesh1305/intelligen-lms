# Local development (with docker compose up -d)
DATABASE_URL="postgresql://intelligen:intelligen@localhost:5432/intelligen_lms"
SESSION_SECRET="change-this-to-a-long-random-string-in-production"
PORT=3001
AVATAR_STORAGE="filesystem"
# MEDIA_STORAGE="database" stores thumbnails in DB on production (like avatars)

# Production (Vercel) — set these in Vercel Project → Environment Variables
# DATABASE_URL="postgresql://..."  (Railway Postgres, Vercel Postgres, or Neon)
# SESSION_SECRET="..."             (openssl rand -base64 32)
# NODE_ENV="production"
# AVATAR_STORAGE="database"
# NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
# CRON_SECRET="..."                (for /api/cron/generate-quizzes)

# Email (optional — logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="IntelliGen LMS <noreply@intelligen.lms>"

# AI Assistant (optional — uses smart local engine without this)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Web Push / PWA (optional — generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@intelligen.lms

# Enterprise SSO (optional — configure redirect URIs to /api/auth/sso/{provider}/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_ISSUER=https://your-org.okta.com/oauth2/default

# Data encryption for 2FA secrets (optional — falls back to SESSION_SECRET)
ENCRYPTION_KEY=

# Razorpay (India — course purchases & subscriptions)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret from Razorpay Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=
