{
  "name": "intelligen-lms",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:clean": "npm run clean && next dev -p 3001",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "next build",
    "vercel-build": "prisma generate && prisma db push --accept-data-loss && next build",
    "start": "node scripts/start-production.mjs",
    "start:local": "next start -p 3001",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-ai-courses": "tsx scripts/seed-ai-courses.ts",
    "db:seed-org": "tsx prisma/seed-demo-org.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "promo:video": "node scripts/generate-promo-video.mjs",
    "screenshots:capture": "node scripts/capture-demo-screenshots.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "jose": "^6.0.11",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "nodemailer": "^7.0.3",
    "otplib": "^13.4.1",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/nodemailer": "^6.4.17",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "ffmpeg-static": "^5.3.0",
    "node-edge-tts": "^1.2.10",
    "playwright": "^1.60.0",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
